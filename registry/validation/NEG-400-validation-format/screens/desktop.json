{
    "extends": "client-error",
    "layout": "inline-toast + highlighted field",
    "copyTitle": "Invalid Format",
    "copyMessageKey": "validation.format",
    "illustration": "red exclamation on field",
    "cta": "none (auto-focus field)",
    "patterns": {
        "inline": {
            "description": "Field-level error with example",
            "usage": "Input forms"
        },
        "modal": {
            "description": "Modal explaining correct format",
            "usage": "Complex inputs"
        }
    },
    "figmaNote": "Duplicate this component → variants for light/dark + RTL. Copy text is resolved via messageKey from localization/messages/",
    "designSystemIntegrations": {
        "tailwind": "class=\"flex items-center gap-2 text-red-600 bg-red-50 p-3 rounded-lg border border-red-200\"",
        "shadcn": "<Alert variant=\"destructive\"><AlertTitle>{title}</AlertTitle><AlertDescription>{t(messageKey)}</AlertDescription></Alert>",
        "material": "<Alert severity=\"error\" icon={<ErrorIcon/>}>{t(messageKey)}</Alert>",
        "ant": "<Alert message={title} description={t(messageKey)} type=\"error\" showIcon />"
    }
}
