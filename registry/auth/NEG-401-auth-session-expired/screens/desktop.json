{
    "extends": "auth-error",
    "layout": "centered illustration",
    "copyTitle": "Session Expired",
    "copyMessageKey": "auth.session-expired",
    "illustration": "clock or lock with timer icon",
    "cta": "Sign in again",
    "patterns": {
        "modal": {
            "description": "Intercept modal when session expires mid-flow",
